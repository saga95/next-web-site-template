{
  "name": "next-enterprise-template",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready Next.js 14 template with TypeScript, Material UI, AWS Amplify, i18n, WCAG 2.2 AA accessibility, and multi-platform deployment.",
  "author": "saga95",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/saga95/next-web-site-template.git"
  },
  "homepage": "https://github.com/saga95/next-web-site-template",
  "keywords": [
    "nextjs",
    "template",
    "typescript",
    "material-ui",
    "aws-amplify",
    "i18n",
    "accessibility",
    "saas",
    "enterprise"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "vercel-build": "next build",
    "prepare": "husky",
    "amplify:sandbox": "npx ampx sandbox",
    "amplify:deploy": "npx ampx pipeline-deploy",
    "bootstrap": "bash scripts/bootstrap.sh",
    "audit": "pnpm audit --audit-level=high",
    "quality:quick": "pnpm lint:check && pnpm type-check && pnpm test",
    "quality": "pnpm format:check && pnpm lint:check && pnpm type-check && pnpm test:coverage && pnpm audit"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^6.0.0",
    "@emailjs/browser": "^4.4.1",
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@hookform/resolvers": "^3.9.0",
    "@mui/icons-material": "^6.1.6",
    "@mui/material": "^6.1.6",
    "@tanstack/react-query": "^4.36.1",
    "aws-amplify": "^6.0.0",
    "critters": "^0.0.23",
    "dayjs": "^1.11.13",
    "dompurify": "^3.3.3",
    "i18next": "^23.16.4",
    "i18next-browser-languagedetector": "^8.0.2",
    "i18next-http-backend": "^2.6.2",
    "next": "14.2.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.53.0",
    "react-i18next": "^15.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@netlify/plugin-nextjs": "^5.7.5",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^15.0.0",
    "next-router-mock": "^1.0.2",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "pnpm": {
    "overrides": {},
    "auditConfig": {
      "ignoreCves": []
    }
  }
}
