# =============================================================================
# ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file: cp .env.example .env.local
# Then fill in your values. Never commit .env.local!
# =============================================================================

# =============================================================================
# REQUIRED — Set these for your project (app works with defaults)
# =============================================================================

# TODO: Update with your project name and deployed URL
NEXT_PUBLIC_APP_NAME=My App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# OPTIONAL — Enable features as needed
# =============================================================================

# --- EmailJS (contact forms) ---
# Sign up: https://www.emailjs.com/
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# --- Analytics ---
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- Error Tracking (Sentry) ---
# NEXT_PUBLIC_SENTRY_DSN=

# --- Feature Flags ---
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_ERROR_TRACKING=false
NEXT_PUBLIC_ENABLE_PWA=false
NEXT_PUBLIC_ENABLE_I18N=true

# =============================================================================
# OPTIONAL — Server-side only (never exposed to browser)
# =============================================================================

# --- API ---
# NEXT_PUBLIC_API_URL=http://localhost:3001
# API_SECRET_KEY=

# --- Database ---
# DATABASE_URL=postgresql://user:pass@localhost:5432/db

# --- Authentication ---
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=

# --- Payments ---
# STRIPE_PUBLIC_KEY=
# STRIPE_SECRET_KEY=

# =============================================================================
# MCP — AI-assisted development (not needed for app runtime)
# =============================================================================

# Figma: https://www.figma.com/developers/api#access-tokens
# FIGMA_PERSONAL_ACCESS_TOKEN=

# GitHub: https://github.com/settings/tokens (scopes: repo, workflow)
# GITHUB_PERSONAL_ACCESS_TOKEN=